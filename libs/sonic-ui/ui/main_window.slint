import { Button, HorizontalBox, VerticalBox } from "std-widgets.slint";
import { ColorTheme } from "components/common.slint";
import { PlayerControls } from "components/player_controls.slint";
import { VisualizerCanvas } from "components/visualizer_canvas.slint";
import { NowPlayingInfo } from "components/track_info.slint";
import { PlaylistView } from "components/playlist_view.slint";

// メインウィンドウ
export component MainWindow inherits Window {
    // ウィンドウプロパティ
    title: "Sonic Flow - Audio Visualizer";
    width: 1400px;
    height: 900px;
    background: ColorTheme.background;
    
    // プレイヤー状態
    in-out property <bool> is-playing: false;
    in-out property <bool> is-paused: false;
    in-out property <string> current-track: "No track loaded";
    in-out property <string> playback-state: "Stopped";
    in-out property <float> volume: 0.8;
    in-out property <float> progress: 0.0;
    in-out property <string> position-text: "00:00";
    in-out property <string> duration-text: "00:00";
    in-out property <string> visualizer-type: "spectrum_bars";
    in-out property <float> visualizer-sensitivity: 1.0;
    in-out property <float> visualizer-smoothing: 0.8;

    // 音質情報
    in-out property <string> file-format: "";
    in-out property <string> sample-rate: "";
    in-out property <string> bit-depth: "";
    in-out property <string> bitrate: "";
    in-out property <string> channels: "";
    
    // トラックメタデータ
    in-out property <string> track-title: "";
    in-out property <string> track-artist: "";
    in-out property <string> track-album: "";
    in-out property <string> track-year: "";
    in-out property <string> track-genre: "";
    in-out property <image> album-artwork: @image-url("");
    
    // プレイリスト状態
    in-out property <bool> playlist-collapsed: false;
    in-out property <int> current-track-index: -1;
    in-out property <int> total-tracks: 5;
    in-out property <string> total-duration: "19:49";

    // コールバック - プレイヤー制御
    callback play-pause-clicked();
    callback stop-clicked();
    callback next-track();
    callback previous-track();
    callback skip-backward();
    callback skip-forward();
    callback volume-changed(float);
    callback seek(float);
    callback load-track-clicked();
    callback shuffle-toggled();
    callback repeat-toggled();
    
    // コールバック - ビジュアライザー
    callback visualizer-changed(string);
    callback visualizer-sensitivity-changed(float);
    callback visualizer-smoothing-changed(float);
    callback fullscreen-toggled();
    callback visualizer-preset-selected(string);
    
    // コールバック - プレイリスト
    callback playlist-toggle-collapsed();
    callback playlist-track-selected(int);
    callback playlist-track-removed(int);
    callback playlist-clear();
    callback playlist-load-folder();
    callback playlist-load-files();
    callback playlist-save();
    callback playlist-folder-selected(string);
    callback playlist-file-selected(string);
    
    VerticalBox {
        padding: 20px;
        spacing: 20px;
        
        // メインコンテンツエリア
        HorizontalBox {
            spacing: 20px;
            horizontal-stretch: 1;
            
            // 左パネル - プレイリスト（折りたたみ可能）
            PlaylistView {
                is-collapsed: root.playlist-collapsed;
                current-track-index: root.current-track-index;
                is-playing: root.is-playing;
                total-tracks: root.total-tracks;
                total-duration: root.total-duration;
                
                toggle-collapsed => { root.playlist-toggle-collapsed(); }
                track-selected(index) => { root.playlist-track-selected(index); }
                track-removed(index) => { root.playlist-track-removed(index); }
                clear-playlist => { root.playlist-clear(); }
                load-folder => { root.playlist-load-folder(); }
                load-files => { root.playlist-load-files(); }
                save-playlist => { root.playlist-save(); }
                folder-selected(path) => { root.playlist-folder-selected(path); }
                file-selected(path) => { root.playlist-file-selected(path); }
            }
            
            // 中央パネル - ビジュアライザー
            VisualizerCanvas {
                horizontal-stretch: 1;
                visualizer-type: root.visualizer-type;
                is-playing: root.is-playing;
                sensitivity: root.visualizer-sensitivity;
                smoothing: root.visualizer-smoothing;
                
                visualizer-changed(type) => { root.visualizer-changed(type); }
                sensitivity-changed(value) => { root.visualizer-sensitivity-changed(value); }
                smoothing-changed(value) => { root.visualizer-smoothing-changed(value); }
                fullscreen-toggled => { root.fullscreen-toggled(); }
                preset-selected(preset) => { root.visualizer-preset-selected(preset); }
            }
            
            // 右パネル - 現在再生中の情報
            NowPlayingInfo {
                width: 280px;
                current-track: root.current-track;
                playback-state: root.playback-state;
                is-playing: root.is-playing;
                
                // メタデータ
                title: root.track-title;
                artist: root.track-artist;
                album: root.track-album;
                year: root.track-year;
                genre: root.track-genre;
                album-artwork: root.album-artwork;
                
                // オーディオ品質
                file-format: root.file-format;
                sample-rate: root.sample-rate;
                bit-depth: root.bit-depth;
                bitrate: root.bitrate;
                channels: root.channels;
            }
        }

        // 下部コントロールバー
        PlayerControls {
            is-playing: root.is-playing;
            is-paused: root.is-paused;
            volume: root.volume;
            progress: root.progress;
            position-text: root.position-text;
            duration-text: root.duration-text;
            
            play-pause-clicked => { root.play-pause-clicked(); }
            stop-clicked => { root.stop-clicked(); }
            next-track => { root.next-track(); }
            previous-track => { root.previous-track(); }
            skip-backward => { root.skip-backward(); }
            skip-forward => { root.skip-forward(); }
            volume-changed(vol) => { root.volume-changed(vol); }
            seek(pos) => { root.seek(pos); }
            load-track-clicked => { root.load-track-clicked(); }
            shuffle-toggled => { root.shuffle-toggled(); }
            repeat-toggled => { root.repeat-toggled(); }
        }
    }
}
