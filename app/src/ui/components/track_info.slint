import { ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { ColorTheme, GlowText, Panel, ProgressIndicator } from "common.slint";

// アルバムアートコンポーネント
component AlbumArt inherits Rectangle {
    in property <image> artwork: @image-url("");
    in property <bool> is-playing: false;
    
    border-radius: ColorTheme.border-radius;
    background: ColorTheme.surface-variant;
    
    if artwork.width > 0: Image {
        source: artwork;
        image-fit: cover;
        
        animate opacity { duration: ColorTheme.animation-normal; }
    }
    
    if artwork.width == 0: Rectangle {
        // デフォルトアートワーク
        background: @linear-gradient(135deg, 
            ColorTheme.surface-variant,
            ColorTheme.surface-elevated
        );
        
        GlowText {
            text: "♫";
            color: ColorTheme.text-muted;
            font-size: Math.min(parent.width, parent.height) * 0.3;
            horizontal-alignment: center;
            vertical-alignment: center;
            glow-active: root.is-playing;
            glow-color: ColorTheme.primary;
        }
    }
    
    // 再生中のアニメーション効果
    if root.is-playing: Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: parent.border-radius;
        border-width: 3px;
        border-color: ColorTheme.primary;
        opacity: 0.7;
        
        animate border-color { 
            duration: 2s; 
        }
    }
}

// オーディオ品質情報
component AudioQualityInfo inherits VerticalBox {
    in property <string> file-format: "";
    in property <string> sample-rate: "";
    in property <string> bit-depth: "";
    in property <string> bitrate: "";
    in property <string> channels: "";
    
    spacing: ColorTheme.spacing-small;
    
    if root.file-format != "": VerticalBox {
        spacing: 6px;

        GlowText {
            text: "Audio Quality";
            color: ColorTheme.text-secondary;
            font-size: ColorTheme.font-size-small;
            font-weight: 700;
        }

        // フォーマット情報
        HorizontalBox {
            spacing: ColorTheme.spacing-small;
            
            GlowText {
                text: "Format:";
                color: ColorTheme.text-muted;
                font-size: ColorTheme.font-size-tiny;
                width: 50px;
            }
            
            GlowText {
                text: root.file-format;
                color: ColorTheme.text-secondary;
                font-size: ColorTheme.font-size-tiny;
                font-weight: 600;
            }
        }

        if root.sample-rate != "": HorizontalBox {
            spacing: ColorTheme.spacing-small;
            
            GlowText {
                text: "Rate:";
                color: ColorTheme.text-muted;
                font-size: ColorTheme.font-size-tiny;
                width: 50px;
            }
            
            GlowText {
                text: root.sample-rate;
                color: ColorTheme.text-secondary;
                font-size: ColorTheme.font-size-tiny;
                font-weight: 600;
            }
        }

        if root.bit-depth != "": HorizontalBox {
            spacing: ColorTheme.spacing-small;
            
            GlowText {
                text: "Depth:";
                color: ColorTheme.text-muted;
                font-size: ColorTheme.font-size-tiny;
                width: 50px;
            }
            
            GlowText {
                text: root.bit-depth;
                color: ColorTheme.text-secondary;
                font-size: ColorTheme.font-size-tiny;
                font-weight: 600;
            }
        }
        
        if root.bitrate != "": HorizontalBox {
            spacing: ColorTheme.spacing-small;
            
            GlowText {
                text: "Bitrate:";
                color: ColorTheme.text-muted;
                font-size: ColorTheme.font-size-tiny;
                width: 50px;
            }
            
            GlowText {
                text: root.bitrate;
                color: ColorTheme.text-secondary;
                font-size: ColorTheme.font-size-tiny;
                font-weight: 600;
            }
        }
        
        if root.channels != "": HorizontalBox {
            spacing: ColorTheme.spacing-small;
            
            GlowText {
                text: "Ch:";
                color: ColorTheme.text-muted;
                font-size: ColorTheme.font-size-tiny;
                width: 50px;
            }
            
            GlowText {
                text: root.channels;
                color: ColorTheme.text-secondary;
                font-size: ColorTheme.font-size-tiny;
                font-weight: 600;
            }
        }
    }
}

// メタデータ情報
component TrackMetadata inherits VerticalBox {
    in property <string> title: "";
    in property <string> artist: "";
    in property <string> album: "";
    in property <string> year: "";
    in property <string> genre: "";
    
    spacing: ColorTheme.spacing-small;
    
    if root.title != "" || root.artist != "" || root.album != "": VerticalBox {
        spacing: 8px;
        
        GlowText {
            text: "Track Info";
            color: ColorTheme.text-secondary;
            font-size: ColorTheme.font-size-small;
            font-weight: 700;
        }
        
        if root.title != "": ScrollView {
            height: 40px;
            GlowText {
                text: root.title;
                color: ColorTheme.text-primary;
                font-size: ColorTheme.font-size-normal;
                font-weight: 600;
                wrap: word-wrap;
            }
        }
        
        if root.artist != "": GlowText {
            text: "by " + root.artist;
            color: ColorTheme.text-secondary;
            font-size: ColorTheme.font-size-small;
            wrap: word-wrap;
        }
        
        if root.album != "": GlowText {
            text: "from " + root.album;
            color: ColorTheme.text-muted;
            font-size: ColorTheme.font-size-small;
            wrap: word-wrap;
        }
        
        if root.year != "" || root.genre != "": HorizontalBox {
            spacing: ColorTheme.spacing-small;
            
            if root.year != "": GlowText {
                text: root.year;
                color: ColorTheme.text-muted;
                font-size: ColorTheme.font-size-tiny;
            }
            
            if root.year != "" && root.genre != "": GlowText {
                text: "•";
                color: ColorTheme.border;
                font-size: ColorTheme.font-size-tiny;
            }
            
            if root.genre != "": GlowText {
                text: root.genre;
                color: ColorTheme.text-muted;
                font-size: ColorTheme.font-size-tiny;
            }
        }
    }
}

// 現在再生中の情報パネル
export component NowPlayingInfo inherits Panel {
    in-out property <string> current-track: "No track loaded";
    in-out property <string> playback-state: "Stopped";
    in-out property <bool> is-playing: false;
    
    // メタデータ
    in-out property <string> title: "";
    in-out property <string> artist: "";
    in-out property <string> album: "";
    in-out property <string> year: "";
    in-out property <string> genre: "";
    
    // オーディオ品質
    in-out property <string> file-format: "";
    in-out property <string> sample-rate: "";
    in-out property <string> bit-depth: "";
    in-out property <string> bitrate: "";
    in-out property <string> channels: "";
    
    // アルバムアート
    in-out property <image> album-artwork: @image-url("");
    
    elevated: true;
    
    VerticalBox {
        padding: ColorTheme.panel-padding;
        spacing: ColorTheme.spacing;
        
        // ヘッダー
        HorizontalBox {
            spacing: ColorTheme.spacing-small;
            
            GlowText {
                text: "Now Playing";
                color: ColorTheme.text-primary;
                font-size: ColorTheme.font-size-large;
                font-weight: 700;
                glow-active: root.is-playing;
                glow-color: ColorTheme.primary;
            }
            
            Rectangle { horizontal-stretch: 1; }
            
            // 再生状態インジケーター
            Rectangle {
                width: 10px;
                height: 10px;
                border-radius: 5px;
                background: root.playback-state == "Playing" ? ColorTheme.success :
                            root.playback-state == "Paused" ? ColorTheme.warning : 
                            ColorTheme.text-muted;
                
                animate background { duration: ColorTheme.animation-normal; }
            }
        }

        // アルバムアート
        AlbumArt {
            height: 120px;
            artwork: root.album-artwork;
            is-playing: root.is-playing;
        }
        
        // 現在のトラック表示（ファイルパス用）
        if root.title == "" && root.current-track != "No track loaded": ScrollView {
            height: 60px;
            
            GlowText {
                text: root.current-track;
                color: ColorTheme.text-primary;
                font-size: ColorTheme.font-size-normal;
                wrap: word-wrap;
            }
        }
        
        // トラックメタデータ
        TrackMetadata {
            title: root.title;
            artist: root.artist;
            album: root.album;
            year: root.year;
            genre: root.genre;
        }
        
        Rectangle {
            height: 1px;
            background: ColorTheme.border;
        }
        
        // 再生状態詳細
        HorizontalBox {
            spacing: ColorTheme.spacing-small;

            GlowText {
                text: "State:";
                color: ColorTheme.text-muted;
                font-size: ColorTheme.font-size-small;
                vertical-alignment: center;
            }

            GlowText {
                text: root.playback-state;
                color: root.playback-state == "Playing" ? ColorTheme.success :
                      root.playback-state == "Paused" ? ColorTheme.warning : 
                      ColorTheme.text-secondary;
                font-size: ColorTheme.font-size-small;
                font-weight: 600;
                vertical-alignment: center;
                glow-active: root.is-playing;
                glow-color: ColorTheme.success;
            }
        }

        // オーディオ品質情報
        AudioQualityInfo {
            file-format: root.file-format;
            sample-rate: root.sample-rate;
            bit-depth: root.bit-depth;
            bitrate: root.bitrate;
            channels: root.channels;
        }

        Rectangle { vertical-stretch: 1; }

        // トラック統計（将来的な拡張用）
        if root.is-playing: VerticalBox {
            spacing: 6px;
            
            GlowText {
                text: "Analysis";
                color: ColorTheme.text-secondary;
                font-size: ColorTheme.font-size-small;
                font-weight: 700;
            }
            
            HorizontalBox {
                spacing: ColorTheme.spacing-small;
                
                GlowText {
                    text: "Peak:";
                    color: ColorTheme.text-muted;
                    font-size: ColorTheme.font-size-tiny;
                    width: 35px;
                }
                
                ProgressIndicator {
                    width: 60px;
                    height: 4px;
                    progress: 0.65;
                    indicator-color: ColorTheme.warning;
                }
                
                GlowText {
                    text: "65%";
                    color: ColorTheme.text-muted;
                    font-size: ColorTheme.font-size-tiny;
                }
            }
            
            HorizontalBox {
                spacing: ColorTheme.spacing-small;
                
                GlowText {
                    text: "RMS:";
                    color: ColorTheme.text-muted;
                    font-size: ColorTheme.font-size-tiny;
                    width: 35px;
                }
                
                ProgressIndicator {
                    width: 60px;
                    height: 4px;
                    progress: 0.45;
                    indicator-color: ColorTheme.success;
                }
                
                GlowText {
                    text: "45%";
                    color: ColorTheme.text-muted;
                    font-size: ColorTheme.font-size-tiny;
                }
            }
        }
    }
}
