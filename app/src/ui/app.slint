import { Button, HorizontalBox, VerticalBox } from "std-widgets.slint";
import { ColorTheme } from "components/common.slint";
import { PlayerControls } from "components/player_controls.slint";
import { VisualizerCanvas } from "components/visualizer_canvas.slint";
import { NowPlayingInfo } from "components/track_info.slint";
import { PlaylistView } from "components/playlist_view.slint";

// UiState is defined here (root file) so that Slint generates Rust bindings for it.
// Sub-components receive properties bound from UiState below.
export global UiState {
    // -- Playback state ---------------------------------------------------
    in-out property <bool>   is-playing: false;
    in-out property <bool>   is-paused: false;
    in-out property <string> playback-state: "Ready";
    in-out property <float>  volume: 0.8;
    in-out property <float>  progress: 0.0;
    in-out property <string> position-text: "00:00";
    in-out property <string> duration-text: "00:00";
    in-out property <string> current-track: "No track loaded";

    // -- Track metadata ---------------------------------------------------
    in-out property <string> track-title: "";
    in-out property <string> track-artist: "";
    in-out property <string> track-album: "";
    in-out property <string> track-year: "";
    in-out property <string> track-genre: "";
    in-out property <image>  album-artwork: @image-url("");

    // -- Audio quality info -----------------------------------------------
    in-out property <string> file-format: "";
    in-out property <string> sample-rate: "";
    in-out property <string> bit-depth: "";
    in-out property <string> bitrate: "";
    in-out property <string> channels: "";

    // -- Visualizer -------------------------------------------------------
    in-out property <string>  visualizer-type: "Spectrum Bars";
    in-out property <float>   visualizer-sensitivity: 1.0;
    in-out property <float>   visualizer-smoothing: 0.5;
    // Frequency band magnitudes for the spectrum visualizer (0.0 – 1.0 each).
    in-out property <[float]> spectrum-bands: [];
    // Instantaneous peak signal level (0.0 – 1.0).
    in-out property <float>   peak-level: 0.0;

    // -- Playlist ---------------------------------------------------------
    in-out property <bool> playlist-collapsed: false;
    in-out property <int>  current-track-index: -1;
    in-out property <int>  total-tracks: 0;
    in-out property <string> total-duration: "00:00";

    // -- Transport callbacks (UI -> Rust) ---------------------------------
    callback play-pause-clicked();
    callback stop-clicked();
    callback next-track();
    callback previous-track();
    callback skip-backward();
    callback skip-forward();
    callback volume-changed(float);
    callback seek(float);
    callback load-track-clicked();
    callback shuffle-toggled();
    callback repeat-toggled();

    // -- Visualizer callbacks ---------------------------------------------
    callback visualizer-changed(string);
    callback visualizer-sensitivity-changed(float);
    callback visualizer-smoothing-changed(float);
    callback fullscreen-toggled();
    callback visualizer-preset-selected(string);

    // -- Playlist callbacks -----------------------------------------------
    callback playlist-toggle-collapsed();
    callback playlist-track-selected(int);
    callback playlist-track-removed(int);
    callback playlist-clear();
    callback playlist-load-folder();
    callback playlist-load-files();
    callback playlist-save();
    callback playlist-folder-selected(string);
    callback playlist-file-selected(string);
}

export component AppWindow inherits Window {
    title: "Sonic Flow";
    width: 1400px;
    height: 750px;
    background: ColorTheme.background;

    VerticalBox {
        padding: 20px;
        spacing: 20px;

        // Main content area — vertical-stretch: 1 lets Slint give it the
        // remaining height after PlayerControls claims its fixed 90px.
        HorizontalBox {
            spacing: 20px;
            horizontal-stretch: 1;
            vertical-stretch: 1;

            // Left panel - Playlist
            PlaylistView {
                is-collapsed: UiState.playlist-collapsed;
                current-track-index: UiState.current-track-index;
                is-playing: UiState.is-playing;
                total-tracks: UiState.total-tracks;
                total-duration: UiState.total-duration;

                toggle-collapsed   => { UiState.playlist-toggle-collapsed(); }
                track-selected(i)  => { UiState.playlist-track-selected(i); }
                track-removed(i)   => { UiState.playlist-track-removed(i); }
                clear-playlist     => { UiState.playlist-clear(); }
                load-folder        => { UiState.playlist-load-folder(); }
                load-files         => { UiState.playlist-load-files(); }
                save-playlist      => { UiState.playlist-save(); }
                folder-selected(p) => { UiState.playlist-folder-selected(p); }
                file-selected(p)   => { UiState.playlist-file-selected(p); }
            }

            // Center panel - Visualizer
            VisualizerCanvas {
                horizontal-stretch: 1;
                visualizer-type: UiState.visualizer-type;
                is-playing:      UiState.is-playing;
                sensitivity:     UiState.visualizer-sensitivity;
                smoothing:       UiState.visualizer-smoothing;
                spectrum-data:   UiState.spectrum-bands;
                peak-level:      UiState.peak-level;

                visualizer-changed(t)   => { UiState.visualizer-changed(t); }
                sensitivity-changed(v)  => { UiState.visualizer-sensitivity-changed(v); }
                smoothing-changed(v)    => { UiState.visualizer-smoothing-changed(v); }
                fullscreen-toggled      => { UiState.fullscreen-toggled(); }
                preset-selected(p)      => { UiState.visualizer-preset-selected(p); }
            }

            // Right panel - Now Playing info
            NowPlayingInfo {
                width: 280px;
                current-track:  UiState.current-track;
                playback-state: UiState.playback-state;
                is-playing:     UiState.is-playing;

                title:          UiState.track-title;
                artist:         UiState.track-artist;
                album:          UiState.track-album;
                year:           UiState.track-year;
                genre:          UiState.track-genre;
                album-artwork:  UiState.album-artwork;

                file-format:    UiState.file-format;
                sample-rate:    UiState.sample-rate;
                bit-depth:      UiState.bit-depth;
                bitrate:        UiState.bitrate;
                channels:       UiState.channels;
            }
        }

        // Bottom control bar
        PlayerControls {
            is-playing:    UiState.is-playing;
            is-paused:     UiState.is-paused;
            volume:        UiState.volume;
            progress:      UiState.progress;
            position-text: UiState.position-text;
            duration-text: UiState.duration-text;

            play-pause-clicked => { UiState.play-pause-clicked(); }
            stop-clicked       => { UiState.stop-clicked(); }
            next-track         => { UiState.next-track(); }
            previous-track     => { UiState.previous-track(); }
            skip-backward      => { UiState.skip-backward(); }
            skip-forward       => { UiState.skip-forward(); }
            volume-changed(v)  => { UiState.volume-changed(v); }
            seek(p)            => { UiState.seek(p); }
            load-track-clicked => { UiState.load-track-clicked(); }
            shuffle-toggled    => { UiState.shuffle-toggled(); }
            repeat-toggled     => { UiState.repeat-toggled(); }
        }
    }
}
