import { Button, ScrollView, ListView, VerticalBox, HorizontalBox, LineEdit } from "std-widgets.slint";
import { ColorTheme, StyledButton, GlowText, Panel } from "common.slint";

// プレイリストアイテム
component PlaylistItem inherits Rectangle {
    in property <string> track-title: "";
    in property <string> artist: "";
    in property <string> duration: "";
    in property <bool> is-current: false;
    in property <bool> is-playing: false;
    in property <int> track-number: 0;
    
    callback clicked();
    callback remove-clicked();
    
    height: 40px;
    background: mouse-area.has-hover ? ColorTheme.surface-variant : 
                root.is-current ? ColorTheme.primary.with-alpha(0.2) : transparent;
    border-radius: ColorTheme.border-radius-small;
    
    animate background { duration: ColorTheme.animation-fast; }
    
    mouse-area := TouchArea {
        clicked => { root.clicked(); }
    }
    
    HorizontalBox {
        padding-left: ColorTheme.panel-padding-small;
        padding-right: ColorTheme.panel-padding-small;
        spacing: ColorTheme.spacing-small;
        
        // トラック番号/再生インジケーター
        Rectangle {
            width: 30px;
            
            if root.is-current && root.is-playing: GlowText {
                text: "▶";
                color: ColorTheme.primary;
                font-size: ColorTheme.font-size-small;
                horizontal-alignment: center;
                vertical-alignment: center;
                glow-active: true;
                glow-color: ColorTheme.primary;
            }
            
            if root.is-current && !root.is-playing: GlowText {
                text: "⏸";
                color: ColorTheme.warning;
                font-size: ColorTheme.font-size-small;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            
            if !root.is-current: GlowText {
                text: root.track-number > 0 ? root.track-number : "";
                color: ColorTheme.text-muted;
                font-size: ColorTheme.font-size-small;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
        
        // トラック情報
        VerticalBox {
            horizontal-stretch: 1;
            spacing: 2px;
            
            GlowText {
                text: root.track-title != "" ? root.track-title : "Unknown Track";
                color: root.is-current ? ColorTheme.primary : ColorTheme.text-primary;
                font-size: ColorTheme.font-size-small;
                font-weight: root.is-current ? 600 : 400;
                overflow: elide;
                glow-active: root.is-current && root.is-playing;
                glow-color: ColorTheme.primary;
            }
            
            if root.artist != "": GlowText {
                text: root.artist;
                color: ColorTheme.text-muted;
                font-size: ColorTheme.font-size-tiny;
                overflow: elide;
            }
        }
        
        // 再生時間
        GlowText {
            text: root.duration;
            color: ColorTheme.text-muted;
            font-size: ColorTheme.font-size-tiny;
            width: 50px;
            horizontal-alignment: right;
            vertical-alignment: center;
        }
        
        // 削除ボタン
        StyledButton {
            text: "×";
            width: 25px;
            height: 25px;
            button-color: ColorTheme.error;
            opacity: mouse-area.has-hover ? 1.0 : 0.0;
            clicked => { root.remove-clicked(); }
            
            animate opacity { duration: ColorTheme.animation-fast; }
        }
    }
}

// フォルダブラウザー
component FolderBrowser inherits VerticalBox {
    in property <[string]> folder-contents: [];
    callback folder-selected(string);
    callback file-selected(string);
    
    spacing: ColorTheme.spacing-small;
    
    GlowText {
        text: "Browse Folders";
        color: ColorTheme.text-secondary;
        font-size: ColorTheme.font-size-small;
        font-weight: 700;
    }
    
    ScrollView {
        height: 150px;
        
        VerticalBox {
            spacing: 2px;
            
            for item in folder-contents: Rectangle {
                height: 30px;
                background: mouse-area.has-hover ? ColorTheme.surface-variant : transparent;
                border-radius: ColorTheme.border-radius-small;
                
                mouse-area := TouchArea {
                    clicked => {
                        // 簡易的なフォルダ判定（最初の文字）
                        root.file-selected(item);
                    }
                }
                
                HorizontalBox {
                    padding: 8px;
                    spacing: ColorTheme.spacing-small;
                    
                    GlowText {
                        text: item;
                        color: ColorTheme.text-secondary;
                        font-size: ColorTheme.font-size-small;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }
        }
    }
}

// プレイリストビュー
export component PlaylistView inherits Panel {
    in-out property <bool> is-collapsed: false;
    in-out property <string> current-playlist-name: "Current Playlist";
    in-out property <int> total-tracks: 0;
    in-out property <string> total-duration: "0:00";
    in-out property <int> current-track-index: -1;
    in-out property <bool> is-playing: false;
    
    // プレイリスト項目（例のデータ）
    in-out property <[{title: string, artist: string, duration: string}]> playlist-items: [
        {title: "Sample Track 1", artist: "Artist 1", duration: "3:45"},
        {title: "Sample Track 2", artist: "Artist 2", duration: "4:12"},
        {title: "Sample Track 3", artist: "Artist 3", duration: "2:58"},
        {title: "Sample Track 4", artist: "Artist 4", duration: "5:23"},
        {title: "Sample Track 5", artist: "Artist 5", duration: "3:31"},
    ];
    
    // フォルダブラウジング用
    in-out property <[string]> folder-contents: [
        "📁 Music",
        "📁 Albums", 
        "📁 Artists",
        "🎵 demo.mp3",
        "🎵 sample.flac",
        "🎵 test.wav"
    ];
    
    // コールバック
    callback toggle-collapsed();
    callback track-selected(int);
    callback track-removed(int);
    callback clear-playlist();
    callback load-folder();
    callback load-files();
    callback save-playlist();
    callback folder-selected(string);
    callback file-selected(string);
    
    width: root.is-collapsed ? 50px : 300px;
    elevated: true;
    
    animate width { duration: ColorTheme.animation-normal; }
    
    VerticalBox {
        padding: root.is-collapsed ? 8px : ColorTheme.panel-padding;
        spacing: root.is-collapsed ? 8px : ColorTheme.spacing;
        
        // ヘッダー
        HorizontalBox {
            spacing: ColorTheme.spacing-small;
            
            StyledButton {
                text: root.is-collapsed ? "📋" : "⮜";
                width: 35px;
                height: 35px;
                button-color: ColorTheme.primary;
                clicked => { root.toggle-collapsed(); }
            }
            
            if !root.is-collapsed: GlowText {
                text: root.current-playlist-name;
                color: ColorTheme.text-primary;
                font-size: ColorTheme.font-size-large;
                font-weight: 700;
                horizontal-stretch: 1;
                vertical-alignment: center;
                overflow: elide;
            }
        }
        
        if !root.is-collapsed: VerticalBox {
            spacing: ColorTheme.spacing;
            
            // プレイリスト統計
            HorizontalBox {
                spacing: ColorTheme.spacing-small;
                
                GlowText {
                    text: root.total-tracks + " tracks";
                    color: ColorTheme.text-secondary;
                    font-size: ColorTheme.font-size-small;
                }
                
                GlowText {
                    text: "•";
                    color: ColorTheme.border;
                    font-size: ColorTheme.font-size-small;
                }
                
                GlowText {
                    text: root.total-duration;
                    color: ColorTheme.text-secondary;
                    font-size: ColorTheme.font-size-small;
                }
                
                Rectangle { horizontal-stretch: 1; }
            }
            
            // クイックアクション
            HorizontalBox {
                spacing: ColorTheme.spacing-small;
                
                StyledButton {
                    text: "📁";
                    width: 60px;
                    height: 30px;
                    button-color: ColorTheme.accent;
                    clicked => { root.load-folder(); }
                }
                
                StyledButton {
                    text: "🎵";
                    width: 60px;
                    height: 30px;
                    button-color: ColorTheme.secondary;
                    clicked => { root.load-files(); }
                }
                
                Rectangle { horizontal-stretch: 1; }
                
                StyledButton {
                    text: "💾";
                    width: 30px;
                    height: 30px;
                    button-color: ColorTheme.primary-variant;
                    clicked => { root.save-playlist(); }
                }
                
                StyledButton {
                    text: "🗑";
                    width: 30px;
                    height: 30px;
                    button-color: ColorTheme.error;
                    clicked => { root.clear-playlist(); }
                }
            }
            
            Rectangle {
                height: 1px;
                background: ColorTheme.border;
            }
            
            // プレイリスト項目
            ScrollView {
                VerticalBox {
                    spacing: 2px;
                    
                    for item[index] in playlist-items: PlaylistItem {
                        track-title: item.title;
                        artist: item.artist;
                        duration: item.duration;
                        track-number: index + 1;
                        is-current: index == root.current-track-index;
                        is-playing: root.is-playing && index == root.current-track-index;
                        
                        clicked => { root.track-selected(index); }
                        remove-clicked => { root.track-removed(index); }
                    }
                    
                    if playlist-items.length == 0: Rectangle {
                        height: 100px;
                        
                        VerticalBox {
                            alignment: center;
                            spacing: 10px;
                            
                            GlowText {
                                text: "📭";
                                font-size: 32px;
                                color: ColorTheme.text-muted;
                                horizontal-alignment: center;
                            }
                            
                            GlowText {
                                text: "No tracks loaded";
                                color: ColorTheme.text-muted;
                                font-size: ColorTheme.font-size-small;
                                horizontal-alignment: center;
                            }
                            
                            GlowText {
                                text: "Load folder or files to start";
                                color: ColorTheme.text-muted;
                                font-size: ColorTheme.font-size-tiny;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }
            }
            
            Rectangle {
                height: 1px;
                background: ColorTheme.border;
            }
            
            // フォルダブラウザー
            FolderBrowser {
                folder-contents: root.folder-contents;
                folder-selected(path) => { root.folder-selected(path); }
                file-selected(path) => { root.file-selected(path); }
            }
        }
        
        if root.is-collapsed: VerticalBox {
            spacing: 8px;
            alignment: center;
            
            // 省略形のトラック数表示
            GlowText {
                text: root.total-tracks;
                color: ColorTheme.text-secondary;
                font-size: ColorTheme.font-size-small;
                font-weight: 700;
                horizontal-alignment: center;
            }
            
            // 省略形の再生インジケーター
            if root.is-playing: Rectangle {
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: ColorTheme.success;
                
                animate background { 
                    duration: 1s; 
                }
            }
        }
    }
}
